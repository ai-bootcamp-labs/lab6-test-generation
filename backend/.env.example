# --- Backend runtime ---
NODE_ENV=development
PORT=3000

# --- Postgres ---
# Local docker-compose default: postgres / postgres / authdb
DATABASE_URL=postgres://postgres:postgres@localhost:5432/authdb

# --- JWT ---
# Replace with a 256-bit secret in any non-dev environment
JWT_SECRET=change-me-in-production-must-be-long-and-random

# --- Cookies ---
COOKIE_DOMAIN=localhost

# --- SMTP (mailhog locally) ---
SMTP_URL=smtp://localhost:1025

# --- Password hashing ---
PASSWORD_BCRYPT_COST=12
