{
  "name": "@lab5/auth-backend",
  "version": "0.1.0",
  "private": true,
  "description": "User Authentication System backend (feature 001-user-auth)",
  "engines": {
    "node": ">=20.0.0 <21"
  },
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --selectProjects e2e",
    "test:load": "ts-node tests/load/auth-endpoints.load.ts",
    "db:migrate": "node-pg-migrate up -m migrations -d DATABASE_URL",
    "db:rollback": "node-pg-migrate down -m migrations -d DATABASE_URL",  
    "test:mutation": "stryker run"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "kysely": "^0.27.4",
    "node-cron": "^3.0.3",
    "node-pg-migrate": "^7.6.1",
    "nodemailer": "^6.9.14",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/autocannon": "^7.12.7",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.15",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "autocannon": "^7.15.0",
    "eslint": "^8.57.0",
    "eslint-plugin-jsdoc": "^48.10.2",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "testcontainers": "^10.10.4",
    "ts-jest": "^29.2.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "~5.4.5"
  }
}
